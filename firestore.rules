rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Projects are public for sharing
      
      allow create: if isSignedIn() 
        && isValidProject(request.resource.data)
        && request.resource.data.creatorUid == request.auth.uid;
        
      allow update: if isOwner(resource.data.creatorUid)
        && isValidProject(request.resource.data)
        && request.resource.data.creatorUid == resource.data.creatorUid; // Immutable owner
        
      allow delete: if isOwner(resource.data.creatorUid);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'blocks', 'creatorUid', 'createdAt'])
        && data.title is string && data.title.size() <= 100
        && data.blocks is string && data.blocks.size() <= 100000
        && data.creatorUid is string
        && data.createdAt is timestamp;
    }
  }
}
